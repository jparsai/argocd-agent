      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(agent_events_received{namespace=~\"$namespace\", agent_name=~\"$agent_name\"}[5m])",
          "legendFormat": "Received",
          "refId": "A"
